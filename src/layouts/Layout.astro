---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Aircond Service Kota Bharu | Servis, Chemical Wash & Repair (Fast)',
  description = 'Perlukan aircond service Kota Bharu? Kami buat servis, chemical wash, repair & topup gas. Cover KB + area berdekatan. WhatsApp untuk quote cepat.',
} = Astro.props;

const whatsappNumber = '60145142044';
const whatsappLink = `https://wa.me/${whatsappNumber}?text=Salam,%20saya%20berminat%20dengan%20servis%20aircond.`;
---

<!doctype html>
<html lang="ms" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://cdn-uicons.flaticon.com/2.6.0/uicons-regular-rounded/css/uicons-regular-rounded.css" />
    <title>{title}</title>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-CGNBTPM6FC"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-CGNBTPM6FC');
    </script>
  </head>
  <body class="bg-white text-gray-800 font-sans">
    <!-- Navbar -->
    <nav class="fixed top-0 w-full bg-white/95 backdrop-blur shadow-sm z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <a href="#" class="flex items-center gap-2">
            <i class="fi fi-rr-snowflake text-2xl text-primary"></i>
            <span class="text-xl font-bold text-primary">Aircond Servis KB</span>
          </a>
          <div class="hidden md:flex items-center gap-6 text-sm font-medium">
            <a href="#servis" class="hover:text-primary transition-colors">Servis</a>
            <a href="#kawasan" class="hover:text-primary transition-colors">Kawasan</a>
            <a href="#kenapa-kami" class="hover:text-primary transition-colors">Kenapa Kami</a>
            <a href="#faq" class="hover:text-primary transition-colors">FAQ</a>
            <a
              href={whatsappLink}
              target="_blank"
              rel="noopener"
              data-gtag-event="whatsapp_click"
              data-gtag-label="navbar"
              class="bg-accent hover:bg-green-600 text-white px-4 py-2 rounded-lg transition-colors inline-flex items-center gap-2"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp Kami
            </a>
          </div>
          <!-- Mobile menu button -->
          <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg hover:bg-gray-100">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
        <!-- Mobile menu -->
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          <div class="flex flex-col gap-3 text-sm font-medium">
            <a href="#servis" class="hover:text-primary transition-colors">Servis</a>
            <a href="#kawasan" class="hover:text-primary transition-colors">Kawasan</a>
            <a href="#kenapa-kami" class="hover:text-primary transition-colors">Kenapa Kami</a>
            <a href="#faq" class="hover:text-primary transition-colors">FAQ</a>
            <a
              href={whatsappLink}
              target="_blank"
              rel="noopener"
              data-gtag-event="whatsapp_click"
              data-gtag-label="mobile_menu"
              class="bg-accent hover:bg-green-600 text-white px-4 py-2 rounded-lg transition-colors inline-flex items-center gap-2 w-fit"
            >
              WhatsApp Kami
            </a>
          </div>
        </div>
      </div>
    </nav>

    <main class="pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-white text-lg font-bold mb-3 flex items-center gap-2">
              <i class="fi fi-rr-snowflake text-2xl"></i> Aircond Servis KB
            </h3>
            <p class="text-sm leading-relaxed">
              Pakar dalam servis, pemasangan & baik pulih aircond di Kota Bharu, Kelantan dan kawasan sekitar.
              Pekerja berpengalaman & profesional dengan harga berpatutan.
            </p>
          </div>
          <div>
            <h4 class="text-white font-semibold mb-3">Pautan Pantas</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="#servis" class="hover:text-white transition-colors">Servis Kami</a></li>
              <li><a href="#kawasan" class="hover:text-white transition-colors">Kawasan Liputan</a></li>
              <li><a href="#kenapa-kami" class="hover:text-white transition-colors">Kenapa Kami</a></li>
              <li><a href="#faq" class="hover:text-white transition-colors">FAQ</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-white font-semibold mb-3">Hubungi Kami</h4>
            <ul class="space-y-2 text-sm">
              <li class="flex items-center gap-2">
                <i class="fi fi-rr-phone-call text-sm"></i> <a href="tel:+60145142044" data-gtag-event="phone_call" data-gtag-label="footer" class="hover:text-white transition-colors">014-514 2044</a>
              </li>
              <li class="flex items-center gap-2">
                <i class="fi fi-rr-envelope text-sm"></i> <a href="mailto:info@aircondservis.my" data-gtag-event="email_click" data-gtag-label="footer" class="hover:text-white transition-colors">info@aircondservis.my</a>
              </li>
              <li class="flex items-center gap-2">
                <i class="fi fi-rr-marker text-sm"></i> Kota Bharu, Kelantan & Sekitar
              </li>
            </ul>
            <a
              href={whatsappLink}
              target="_blank"
              rel="noopener"
              data-gtag-event="whatsapp_click"
              data-gtag-label="footer"
              class="mt-4 inline-flex items-center gap-2 bg-accent hover:bg-green-600 text-white px-4 py-2 rounded-lg text-sm transition-colors"
            >
              WhatsApp Kami Sekarang
            </a>
          </div>
        </div>
        <div class="border-t border-gray-700 mt-8 pt-8 text-center text-sm">
          <p>&copy; {new Date().getFullYear()} Aircond Servis. Hak Cipta Terpelihara.</p>
        </div>
      </div>
    </footer>

    <!-- WhatsApp Floating Button -->
    <a
      href={whatsappLink}
      target="_blank"
      rel="noopener"
      data-gtag-event="whatsapp_click"
      data-gtag-label="floating_button"
      class="fixed bottom-6 right-6 bg-green-500 hover:bg-green-600 text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg hover:shadow-xl transition-all z-50"
      aria-label="WhatsApp"
    >
      <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    </a>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
      menu?.querySelectorAll('a').forEach(link =>
        link.addEventListener('click', () => menu?.classList.add('hidden'))
      );

      // GA4 event tracking for CTAs
      document.querySelectorAll('[data-gtag-event]').forEach(el => {
        el.addEventListener('click', () => {
          const event = el.getAttribute('data-gtag-event');
          const label = el.getAttribute('data-gtag-label') || '';
          if (typeof gtag === 'function') {
            gtag('event', event, {
              event_category: 'engagement',
              event_label: label,
            });
          }
        });
      });
    </script>
  </body>
</html>

---
import Layout from '../layouts/Layout.astro';

const whatsappNumber = '60145142044';
const whatsappLink = `https://wa.me/${whatsappNumber}?text=Salam,%20saya%20nak%20tanya%20pasal%20servis%20aircond.`;

const benefits = [
  'Aircond kurang sejuk / tak sejuk: diagnosis & repair',
  'Servis biasa atau chemical wash (ikut keadaan)',
  'Topup gas + check kebocoran (jika perlu)',
  'Cuci filter, blower & indoor/outdoor unit',
  'Slot cepat untuk Kota Bharu & area dekat',
];

const services = [
  {
    icon: 'fi-rr-wrench-simple',
    title: 'Servis Aircond (Standard)',
    desc: 'Cuci basic, check performance, nasihat penjagaan. Sesuai untuk servis berkala supaya aircond sentiasa sejuk dan jimat elektrik.',
    image: '/images/service-standard.svg',
  },
  {
    icon: 'fi-rr-flask',
    title: 'Chemical Wash',
    desc: 'Untuk aircond berbau, airflow lemah, atau coil kotor teruk. Deep clean indoor & outdoor unit untuk prestasi macam baru.',
    image: '/images/service-chemical.svg',
  },
  {
    icon: 'fi-rr-tools',
    title: 'Repair / Baik Pulih',
    desc: 'Water leaking, bunyi kuat, trip, fan problem, sensor/PCB — ikut model. Diagnosis dulu, harga dimaklumkan sebelum kerja.',
    image: '/images/service-repair.svg',
  },
  {
    icon: 'fi-rr-box-open',
    title: 'Installation / Relocation',
    desc: 'Pasang aircond baru atau buka/pindah unit sedia ada. Termasuk copper piping dan pendawaian — ikut site.',
    image: '/images/service-install.svg',
  },
];

const areas = [
  'Kota Bharu', 'Pengkalan Chepa', 'Kubang Kerian', 'Wakaf Che Yeh',
  'Wakaf Bharu', 'Pasir Mas', 'Tumpat', 'Bachok',
  'Salor', 'Peringat', 'Lundang', 'Kadok',
];

const whyUs = [
  {
    icon: 'fi-rr-bolt',
    title: 'Respons Pantas & Kemas',
    desc: 'WhatsApp kami, kami reply cepat dan aturkan slot secepat mungkin.',
  },
  {
    icon: 'fi-rr-money-bill-wave',
    title: 'Harga Jelas Sebelum Kerja',
    desc: 'Tiada caj tersembunyi. Harga dimaklumkan dan dipersetujui sebelum kerja bermula.',
  },
  {
    icon: 'fi-rr-camera',
    title: 'Gambar Sebelum & Selepas',
    desc: 'Kami boleh sediakan gambar sebelum/selepas kerja jika diminta untuk kepuasan anda.',
  },
  {
    icon: 'fi-rr-shield-check',
    title: 'Warranty Kerja',
    desc: 'Kerja kami ada warranty. Jika ada masalah selepas servis, hubungi kami semula.',
  },
];

const faqs = [
  {
    q: 'Aircond tak sejuk — perlu servis atau tambah gas?',
    a: 'Bergantung kepada keadaan. Kadang-kadang cuma filter kotor, kadang memang gas dah kurang. Juruteknik kami akan check dan maklumkan sebelum buat apa-apa kerja tambahan.',
  },
  {
    q: 'Bila perlu chemical wash?',
    a: 'Kalau aircond dah berbau, airflow lemah walaupun dah cuci filter, atau dah lebih setahun tak servis — chemical wash sangat disyorkan untuk pulihkan prestasi.',
  },
  {
    q: 'Kenapa aircond bocor air?',
    a: 'Biasanya sebab drain pipe tersumbat, coil terlalu kotor, atau gas kurang. Kami akan check punca sebenar dan selesaikan masalah.',
  },
  {
    q: 'Berapa lama proses servis?',
    a: 'Servis standard biasa ambil sekitar 30-60 minit. Chemical wash boleh ambil 1-2 jam bergantung keadaan unit.',
  },
  {
    q: 'Servis untuk 1.0HP / 1.5HP / 2.0HP sama ke?',
    a: 'Proses servis sama, tapi harga mungkin berbeza mengikut HP/saiz unit. Hubungi kami untuk quotation tepat.',
  },
  {
    q: 'Cover area luar Kota Bharu?',
    a: 'Ya, kami cover Kota Bharu, Pengkalan Chepa, Kubang Kerian, Wakaf Che Yeh dan kawasan berdekatan. Kalau tak pasti, WhatsApp kami untuk confirm.',
  },
];
---

<Layout>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-primary to-primary-dark text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <i class="fi fi-rr-snowflake absolute top-10 left-10 text-[10rem] text-white"></i>
      <i class="fi fi-rr-snowflake absolute bottom-10 right-10 text-[10rem] text-white"></i>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 relative">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block bg-white/20 text-white text-sm font-medium px-4 py-1.5 rounded-full mb-6">
            <i class="fi fi-rr-bolt mr-1"></i> Fast Response · Kota Bharu & Sekitar
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
            Aircond Service Kota Bharu — <span class="text-secondary">Servis, Chemical Wash & Repair</span>
          </h1>
          <p class="text-lg md:text-xl text-blue-100 mb-8 leading-relaxed">
            Untuk rumah & kedai sekitar Kota Bharu. Juruteknik berpengalaman, harga jelas, boleh WhatsApp untuk booking hari ini.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href={whatsappLink}
              target="_blank"
              rel="noopener"
              data-gtag-event="whatsapp_click"
              data-gtag-label="hero"
              class="bg-accent hover:bg-green-600 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-all hover:shadow-lg inline-flex items-center justify-center gap-2"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp Sekarang
            </a>
            <a
              href="tel:+60145142044"
              data-gtag-event="phone_call"
              data-gtag-label="hero"
              class="border-2 border-white/30 hover:bg-white/10 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-all inline-flex items-center justify-center gap-2"
            >
              <i class="fi fi-rr-phone-call mr-1"></i> Call Now
            </a>
          </div>
        </div>
        <!-- GAMBAR: Juruteknik sedang servis aircond di rumah pelanggan -->
        <div class="hidden lg:block">
          <img
            src="/images/hero-technician.svg"
            alt="Juruteknik aircond sedang servis unit di Kota Bharu"
            class="rounded-2xl shadow-2xl w-full h-auto"
            width="600"
            height="450"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits + Before/After -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Apa Yang Kami Boleh Bantu</h2>
          <ul class="space-y-4">
            {benefits.map((b) => (
              <li class="flex items-start gap-3 bg-white rounded-xl p-4 shadow-sm">
                <i class="fi fi-rr-check-circle text-accent text-xl mt-0.5"></i>
                <span class="text-gray-700 font-medium">{b}</span>
              </li>
            ))}
          </ul>
        </div>
        <!-- GAMBAR: Before/After chemical wash -->
        <div class="space-y-4">
          <p class="text-sm font-semibold text-gray-500 uppercase tracking-wide text-center">Hasil Kerja Kami — Sebelum & Selepas</p>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <img
                src="/images/before-after-1.svg"
                alt="Coil aircond sebelum chemical wash — kotor dan berhabuk"
                class="rounded-xl w-full h-auto shadow-sm"
                width="400"
                height="300"
              />
              <p class="text-center text-sm text-gray-500 mt-2 font-medium">Sebelum</p>
            </div>
            <div>
              <img
                src="/images/before-after-2.svg"
                alt="Coil aircond selepas chemical wash — bersih seperti baru"
                class="rounded-xl w-full h-auto shadow-sm"
                width="400"
                height="300"
              />
              <p class="text-center text-sm text-gray-500 mt-2 font-medium">Selepas</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Perkhidmatan Kami -->
  <section id="servis" class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Perkhidmatan Kami</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Semua jenis kerja aircond untuk rumah dan kedai di Kota Bharu dan sekitar.</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-8">
        {services.map((s) => (
          <div class="bg-white border-2 border-gray-100 rounded-2xl overflow-hidden hover:border-primary/30 transition-colors">
            <!-- GAMBAR: Foto berkaitan servis ini -->
            <img
              src={s.image}
              alt={s.title}
              class="w-full h-48 object-cover"
              width="400"
              height="192"
            />
            <div class="p-8">
              <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mb-4">
                <i class={`fi ${s.icon} text-2xl text-primary`}></i>
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-3">{s.title}</h3>
              <p class="text-gray-600 leading-relaxed">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Kawasan Liputan -->
  <section id="kawasan" class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Kawasan Liputan</h2>
          <p class="text-gray-600 mb-8">Kota Bharu dan kawasan berdekatan. Tak pasti area anda? WhatsApp kami untuk confirm.</p>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {areas.map((area) => (
              <div class="bg-white rounded-xl p-3 text-center shadow-sm hover:bg-primary hover:text-white transition-colors cursor-default">
                <span class="text-sm font-medium"><i class="fi fi-rr-marker mr-1"></i> {area}</span>
              </div>
            ))}
          </div>
          <p class="text-gray-500 text-sm mt-4">+ area berdekatan — tanya kami untuk confirm.</p>
        </div>
        <!-- GAMBAR: Team photo / van servis -->
        <div>
          <img
            src="/images/team-photo.svg"
            alt="Pasukan juruteknik Aircond Servis KB di Kota Bharu"
            class="rounded-2xl shadow-lg w-full h-auto"
            width="600"
            height="400"
          />
          <p class="text-center text-sm text-gray-500 mt-3">Pasukan kami sedia berkhidmat di Kota Bharu & sekitar</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Kenapa Pilih Kami -->
  <section id="kenapa-kami" class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Kenapa Pilih Kami?</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {whyUs.map((w) => (
          <div class="text-center">
            <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <i class={`fi ${w.icon} text-3xl text-primary`}></i>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">{w.title}</h3>
            <p class="text-gray-600 text-sm">{w.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Galeri Kerja -->
  <section id="galeri" class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Galeri Kerja Kami</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Contoh kerja sebenar dari pelanggan kami di Kota Bharu dan sekitar.</p>
      </div>
      <!-- GAMBAR: 6 gambar portfolio kerja sebenar -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <img src="/images/gallery-1.svg" alt="Kerja servis aircond - cuci filter" class="rounded-xl w-full h-48 object-cover shadow-sm" width="400" height="192" />
        <img src="/images/gallery-2.svg" alt="Kerja chemical wash aircond" class="rounded-xl w-full h-48 object-cover shadow-sm" width="400" height="192" />
        <img src="/images/gallery-3.svg" alt="Pemasangan aircond baru siap" class="rounded-xl w-full h-48 object-cover shadow-sm" width="400" height="192" />
        <img src="/images/gallery-4.svg" alt="Repair aircond - tukar part" class="rounded-xl w-full h-48 object-cover shadow-sm" width="400" height="192" />
        <img src="/images/gallery-5.svg" alt="Before after chemical wash coil" class="rounded-xl w-full h-48 object-cover shadow-sm" width="400" height="192" />
        <img src="/images/gallery-6.svg" alt="Juruteknik sedang troubleshoot aircond" class="rounded-xl w-full h-48 object-cover shadow-sm" width="400" height="192" />
      </div>
    </div>
  </section>

  <!-- Testimoni Pelanggan -->
  <section id="testimoni" class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Apa Kata Pelanggan Kami</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Screenshot review sebenar dari pelanggan di Kota Bharu.</p>
      </div>
      <!-- GAMBAR: Screenshot WhatsApp review / Google review -->
      <div class="grid sm:grid-cols-3 gap-6">
        <div class="bg-gray-50 rounded-2xl p-3">
          <img
            src="/images/testimonial-1.svg"
            alt="Screenshot review pelanggan - servis aircond Kota Bharu"
            class="rounded-xl w-full h-auto"
            width="400"
            height="500"
          />
        </div>
        <div class="bg-gray-50 rounded-2xl p-3">
          <img
            src="/images/testimonial-2.svg"
            alt="Screenshot review pelanggan - chemical wash aircond"
            class="rounded-xl w-full h-auto"
            width="400"
            height="500"
          />
        </div>
        <div class="bg-gray-50 rounded-2xl p-3">
          <img
            src="/images/testimonial-3.svg"
            alt="Screenshot review pelanggan - pasang aircond baru"
            class="rounded-xl w-full h-auto"
            width="400"
            height="500"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-gradient-to-r from-primary to-primary-dark text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Aircond Bermasalah? Jangan Tunggu Lama.
      </h2>
      <p class="text-blue-100 text-lg mb-8 max-w-2xl mx-auto">
        Slot kami terhad setiap hari. <strong>WhatsApp kami sekarang</strong> untuk booking slot atau dapatkan quote cepat.
      </p>
      <a
        href={whatsappLink}
        target="_blank"
        rel="noopener"
        data-gtag-event="whatsapp_click"
        data-gtag-label="cta_banner"
        class="bg-accent hover:bg-green-600 text-white font-bold px-10 py-4 rounded-xl text-lg transition-all hover:shadow-lg inline-flex items-center gap-3"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp Sekarang — Booking / Quote
      </a>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="py-20 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Soalan Lazim (FAQ)</h2>
        <p class="text-gray-600">Jawapan kepada soalan yang sering ditanya pelanggan kami.</p>
      </div>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-white rounded-xl shadow-sm">
            <summary class="flex justify-between items-center cursor-pointer p-6 font-semibold text-gray-900 hover:text-primary transition-colors">
              {faq.q}
              <span class="ml-4 text-gray-400 group-open:rotate-180 transition-transform">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </summary>
            <div class="px-6 pb-6 text-gray-600">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>
